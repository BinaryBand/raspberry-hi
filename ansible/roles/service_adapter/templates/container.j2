[Unit]
Description={{ container_description }}
After=network.target
{% for dep in container_unit_after | default([]) %}
After={{ dep }}
{% endfor %}
{% for dep in container_unit_requires | default([]) %}
Requires={{ dep }}
{% endfor %}

[Container]
Image={{ container_image }}
ContainerName={{ container_name }}
{% if container_pod | default('') %}
Pod={{ container_pod }}.pod
{% else %}
{% for port in container_ports | default([]) %}
PublishPort={{ port }}
{% endfor %}
{% endif %}
{% for vol in container_volumes | default([]) %}
Volume={{ vol }}
{% endfor %}
{% if container_exec | default('') %}
Exec={{ container_exec }}
{% endif %}
{% if container_env_file | default('') %}
EnvironmentFile={{ container_env_file }}
{% endif %}

[Service]
Restart=on-failure
RestartSec=5
TimeoutStartSec=300

[Install]
WantedBy=default.target
