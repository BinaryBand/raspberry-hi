# mautrix-whatsapp appservice registration — managed by Ansible.
# Copy this file to your Matrix homeserver and register it before starting the bridge.
id: whatsapp
url: {{ mautrix_whatsapp_appservice_address }}
as_token: {{ mautrix_whatsapp_as_token }}
hs_token: {{ mautrix_whatsapp_hs_token }}
sender_localpart: whatsappbot
rate_limited: false
namespaces:
  users:
    - exclusive: true
      regex: '@whatsapp_.*:{{ mautrix_whatsapp_homeserver_domain }}'
    - exclusive: true
      regex: '@whatsappbot:{{ mautrix_whatsapp_homeserver_domain }}'
  aliases: []
  rooms: []
de.sorunome.msc2409.push_ephemeral: true
push_ephemeral: true
